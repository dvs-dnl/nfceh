#!/bin/bash
# Pre-push gate for nfceh.org — installed by install-hooks.sh
# Blocks any push that fails a critical gate.
echo "Running pre-push gates (scripts/gate-check.py)..."
cd "$(git rev-parse --show-toplevel)"
python3 scripts/gate-check.py
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "PUSH BLOCKED: fix the critical gate failures above, commit, and push again."
  exit 1
fi
exit 0
